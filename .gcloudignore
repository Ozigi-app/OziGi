# Tell gcloud builds submit what NOT to upload.
# Without this, node_modules and .next get uploaded (gigabytes) and time out.
.gcloudignore

# Git
.git
.gitignore

# Dependencies — Docker installs these fresh inside the container
node_modules/
.pnp
.pnp.*
.yarn/

# Next.js build output
.next/
out/
build/
dist-worker/

# Test artifacts
coverage/
playwright-report/
test-results/

# Local env files — pass secrets via --set-env-vars instead
.env*
gcp-service-account.json

# Editor / OS
.DS_Store
*.pem
.vercel

# Logs
npm-debug.log*
yarn-debug.log*
